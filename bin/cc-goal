#!/bin/bash
# cc-goal — set a worker's PERSISTENT session goal via Claude Code /goal command.
# Updated (operator lesson "don't use a GOAL: text prefix, use the /goal cmd"):
#   DEFAULT now uses the /goal slash command (persistent, status-bar anchored),
#   NOT a "GOAL: " text prefix. The literal-prefix approach is deprecated.
#
# Usage:
#   cc-goal <session> "<persistent objective>"
#       → ts "<session>" "/goal <objective>"  (sets status-bar-anchored goal)
#   cc-goal <session> --nudge "<tactical next-step>"
#       → ts "<session>" "<msg>"  (plain tactical message, NO prefix)
#
# /goal for persistent anchoring; plain ts for tactical per-cycle nudges.
# No "GOAL:" text tag anymore.

set -e

[ $# -ge 2 ] || { echo "Usage: cc-goal <session> [--nudge] '<message>'" >&2; exit 2; }

NAME="$1"; shift
TS="$HOME/.local/bin/ts"

# ── _cc_goal_stamp: LOCKED + ATOMIC registry update ──────────────────────────
# The old inline `reg = json.loads(p.read_text()); ...; p.write_text(...)` was an
# UNLOCKED read-modify-write. Two concurrent cc-goal calls (cc-watch keepalive shells
# out to cc-goal per stalled worker while the manager may run cc-goal by hand) race:
# the slower writer's snapshot is stale → the other worker's update is SILENTLY LOST.
# Worse, write_text() truncates-then-writes (non-atomic); a kill mid-write (cc-watch
# SIGALRM) leaves a PARTIAL/empty workers.json that crashes EVERY downstream
# json.loads reader (cc-watch / cc-monitor / cc-roster go blind).
# Fix: exclusive lock (O_EXCL, stale-steal >15s so no deadlock) → re-read under lock →
# write to a temp file → os.replace() atomic rename. goal == __CLEAR__ sentinel writes
# "". `|| true` keeps set -e from aborting on a missing/corrupt registry (degrade to
# stale roster, never crash the caller).
_cc_goal_stamp() {
    python3 - "$1" "$2" "$3" <<'PY' 2>/dev/null || true
import json, sys, os, time, tempfile
from datetime import datetime
from pathlib import Path
name, goal, regpath = sys.argv[1], sys.argv[2], sys.argv[3]
clear = (goal == "__CLEAR__")
p = Path(regpath)
lock = Path(regpath + ".lock")
fd = None
for _ in range(50):                       # ~5s of retries
    try:
        fd = os.open(str(lock), os.O_CREAT | os.O_EXCL | os.O_WRONLY)
        break
    except FileExistsError:
        try:
            if time.time() - lock.stat().st_mtime > 15:   # steal a crashed writer's stale lock
                lock.unlink(); continue
        except FileNotFoundError:
            continue
        time.sleep(0.1)
try:
    reg = json.loads(p.read_text())       # RE-READ under lock → no lost update
    for w in reg.get("workers", []):
        if w.get("name") == name:
            w["current_goal"] = "" if clear else goal
            w["goal_updated"] = datetime.now().isoformat()
            break
    data = json.dumps(reg, indent=2, ensure_ascii=False)
    tf = tempfile.NamedTemporaryFile("w", dir=str(p.parent), prefix=".workers.",
                                     suffix=".tmp", delete=False, encoding="utf-8")
    try:
        tf.write(data); tf.flush(); os.fsync(tf.fileno()); tf.close()
        os.replace(tf.name, str(p))       # atomic rename → readers never see a partial file
    except BaseException:
        os.unlink(tf.name); raise
finally:
    if fd is not None:
        os.close(fd)
        try: lock.unlink()
        except FileNotFoundError: pass
PY
}

if [ "$1" = "--nudge" ]; then
    shift
    MSG="$*"
    # NO-UNBOUNDED-LOOPS advisory: the primary /loop issuance is the manager hand-typing a /loop
    # here — the one path with no terminal check. When MSG contains '/loop', grep for at least one
    # checkable STOP token (metric-hit | certified-terminal | deadline/round-cap). If NONE, emit ONE
    # non-blocking stderr reminder and STILL send (advisory only; CC_LOOP_FORCE=1 silences). Fires
    # ONLY on a literal '/loop' → cannot nag plain nudges. `|| true` guards every grep for set -e.
    # No runtime/round-count detector is added (serial bounded loops are allowed; round-count
    # false-positives the long-but-bounded loop).
    if [ -z "${CC_LOOP_FORCE:-}" ] && printf '%s' "$MSG" | grep -q '/loop'; then
        _has_terminal=0
        printf '%s' "$MSG" | grep -qiE 'Sharpe|CAGR|Calmar|达成|才停|>=|≥' && _has_terminal=1 || true
        printf '%s' "$MSG" | grep -qiE 'certified|consecutive DEAD|穷尽|证死|cc-task done|frontier exhausted|exhausted|terminal|终局' && _has_terminal=1 || true
        printf '%s' "$MSG" | grep -qiE 'deadline|round-cap|rounds?|轮|<=|≤|round.?cap' && _has_terminal=1 || true
        [ "$_has_terminal" = 0 ] && echo "⚠ cc-goal: this /loop names no terminal (metric-hit | certified-terminal | deadline/round-cap) — per NO-UNBOUNDED-LOOPS every /loop MUST carry a checkable stop; set CC_LOOP_FORCE=1 to silence" >&2
    fi
    "$TS" "$NAME" "$MSG"            # plain tactical nudge, no prefix (advisory above never blocks)
    echo "nudge sent -> $NAME: ${MSG:0:60}" >&2
else
    MSG="$*"
    # FIX #1: READ-THEN-SET advisory guard. When a goal asserts a
    # hard ceiling / scope switch / bar-raise it SHOULD cite the ledger evidence it is
    # overriding. Heuristic assertion = a metric target (a metric name + a number) OR pivot/ceiling
    # words. If such an assertion appears
    # but the text carries NO run-id and NO ledger/verdict reference, emit a
    # NON-BLOCKING stderr warning and still SEND (CC_GOAL_FORCE=1 silences nothing — the workflow
    # is never broken; this is advisory only). `|| true` guards every grep so `set -e` can't abort.
    _asserts=0
    echo "$MSG" | grep -qiE 'Sharpe[^0-9]{0,12}[0-9]' && _asserts=1 || true
    echo "$MSG" | grep -qiE '天花板|ceiling|不可达|换|crypto|shorts|部署|deploy' && _asserts=1 || true
    if [ "$_asserts" = 1 ]; then
        _has_evidence=0
        echo "$MSG" | grep -qiE '[0-9a-f]{32}' && _has_evidence=1 || true       # run-id (32-hex)
        echo "$MSG" | grep -qiE 'PERF_CARD|verdict|\bbt\b' && _has_evidence=1 || true
        if [ "$_has_evidence" = 0 ]; then
            echo "⚠ cc-goal: this goal asserts a ceiling/target/pivot but cites no run-id/ledger/verdict — per READ-THEN-SET, quote the ledger evidence you're overriding (set CC_GOAL_FORCE=1 to send anyway)" >&2
        fi
    fi
    # Reliable /goal: VERIFY the new goal actually anchored before stamping the
    # registry. The worker echoes a fresh "Goal set: <text>" line every time /goal
    # lands; just grepping "goal active" is a FALSE positive (true for ANY prior
    # goal — including one the WORKER set on itself, which silently overwrites the
    # manager mandate). Observed bug: registry showed the new goal while the
    # session anchor was stale/worker-hijacked → roster lied (observed bug).
    # grep -c exits 1 on zero matches → would trip set -e; `|| true` guards it.
    _gcount() { tmux capture-pane -p -t "$NAME" -S -2000 2>/dev/null | grep -c "Goal set:" || true; }
    before=$(_gcount); landed=0
    for attempt in 1 2 3; do
        "$TS" "$NAME" "/goal $MSG"
        sleep 4
        if [ "$(_gcount)" -gt "$before" ]; then landed=1; break; fi
        sleep 4   # maybe still mid-stream; give it a beat, then retry
    done
    LAST=$(tmux capture-pane -p -t "$NAME" -S -400 2>/dev/null | grep "Goal set:" | tail -1)
    if [ "$landed" = 1 ]; then
        echo "/goal set+verified -> $NAME: ${MSG:0:50}" >&2
        echo "   anchor now: ${LAST#*Goal set: }" >&2
    else
        echo "⚠ /goal did NOT anchor on $NAME after 3 tries — registry NOT stamped." >&2
        echo "   (worker may be swallowing the command mid-stream; re-run cc-goal when calmer.)" >&2
        exit 4
    fi

    # Stamp registry current_goal ONLY after verified landing (no more lying roster).
    # LOCKED + ATOMIC (see _cc_goal_stamp): concurrent cc-goal / cc-watch keepalive can't
    # lose this update or leave a half-written workers.json. goal_updated stamps WHEN the
    # persistent /goal anchor was last refreshed — cc-monitor's check_goal_stale compares it
    # to each open task's created_at to catch "only --nudged, never re-/goal" drift.
    REGISTRY="$HOME/.cc-manager/workers.json"
    if [ -f "$REGISTRY" ]; then
        _cc_goal_stamp "$NAME" "$MSG" "$REGISTRY"
    fi
fi
