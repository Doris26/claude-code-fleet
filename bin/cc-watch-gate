#!/usr/bin/env bash
# cc-watch-gate — the 30-min cc-watch cron must run ONLY when a worker GENUINELY has an unfinished
# goal (user 2026-06-30: "除非真的有员工有 goal 没完成 不然不要 30min 的 cron").
#
# WHY GOAL-BASED (not signal-based): each cron subagent spawn costs ~30k tokens regardless of work
# found. An earlier version gated on transient signals (new commit since cursor / uncommitted changes
# / a pane showing 'esc to interrupt') — but ANY of those can persist with NO active goal and SPAWN
# every tick forever: a single stray uncommitted scratch file, a stuck review cursor (cc-review can't
# advance), or a wedged pane → ~48 x 30k = ~1.4M tok/day LEAK. So the gate keys on the ONE durable
# signal of real outstanding work: does any active, non-parked worker still carry a non-empty
# current_goal in workers.json? A done / idle / parked / standing-by worker has current_goal=="" (the
# deliberate-idle convention honored fleet-wide). No unfinished-goal worker ⇒ no active work ⇒ the
# cron should not run at all (delete it; review any one-off commit manually).
#
# Prints exactly one line:
#   SPAWN <reason>  -> >=1 worker has an unfinished goal; the cron spawns the full cc-watch subagent
#   SKIP <reason>   -> fleet has no unfinished-goal worker; skip the subagent (and the cron should be deleted)
# Fails OPEN to SPAWN on any read/parse error so supervision is never silently dropped.
set -uo pipefail
WORKERS="$HOME/.cc-manager/workers.json"
[ -f "$WORKERS" ] || { echo "SPAWN workers.json-missing (fail-open)"; exit 0; }
python3 - "$WORKERS" <<'PY'
import json, sys
try:
    d = json.load(open(sys.argv[1]))
except Exception as e:
    print(f"SPAWN workers.json-parse-error ({e}) (fail-open)"); sys.exit(0)
unfinished = [w.get("name", "?") for w in d.get("workers", [])
              if w.get("status") == "active"
              and not w.get("parked")
              and w.get("name") != "manager"
              and (w.get("current_goal") or "").strip()]
if unfinished:
    head = ", ".join(unfinished[:6]) + (" …" if len(unfinished) > 6 else "")
    print(f"SPAWN unfinished-goal worker(s): {head}")
else:
    print("SKIP no unfinished-goal worker (fleet idle/done — the cron should be deleted)")
PY
