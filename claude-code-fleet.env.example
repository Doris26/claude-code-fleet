# claude-code-fleet configuration — copy to `claude-code-fleet.env` and edit, or export these in your shell profile.
#
# The scripts read each value as `${VAR:-<default>}`, so you only need to set the
# ones whose default doesn't fit your setup. The two you almost always set are
# CC_REPO and CC_EXPECT_ACCT.

# --- Required-ish ------------------------------------------------------------

# Absolute path to the git repo your worker fleet commits to. The supervisor
# reviews commits here, resolves landing-proof, etc. If unset, the scripts try
# to auto-detect the current git root, falling back to "$HOME/your-repo".
export CC_REPO="${CC_REPO:-$HOME/your-repo}"

# The Claude Code account the fleet is supposed to run under
# (oauthAccount.emailAddress in ~/.claude.json). The supervisor FREEZES the
# whole tick if the active account drifts away from this — on a shared machine
# the CLI account can silently switch and spawn workers under the wrong quota.
# There is NO safe default: set this to your account or the account-guard is a no-op.
export CC_EXPECT_ACCT="${CC_EXPECT_ACCT:-you@example.com}"

# --- Optional ----------------------------------------------------------------

# State dir for watch.list, locks, logs, escalations. Default is fine for most.
export CC_STATE_DIR="${CC_STATE_DIR:-$HOME/.cc-manager}"

# Install dir (where bin/, plugins/, personas/ live). The cc-* commands auto-detect this from their
# own location (symlink-aware), so you normally DON'T set it. `./install.sh` pins the correct value
# into your generated claude-code-fleet.env. Only set it manually if auto-detection ever fails.
# export CC_HOME="/absolute/path/to/claude-code-fleet"

# git author identity the managed worker sessions commit under. Used to tell a
# managed worker-bot commit apart from a human colleague's commit (advisory-only
# routing). Defaults to the expected account; set CC_BOT_NAME if your bot commits
# under a distinct git user.name.
export CC_BOT_NAME="${CC_BOT_NAME:-}"
export CC_BOT_EMAIL="${CC_BOT_EMAIL:-$CC_EXPECT_ACCT}"

# Verification provider plugin (see plugins/README.md). This is how the review
# gate independently checks that a result a worker CITES in a commit actually
# exists in ground truth (so a worker can't fabricate a metric and pass review).
#   plugins/generic  — default: surfaces cited artifact ids/URLs, verdict SKIP
#                      (no backend; the framework runs domain-agnostic out of the box)
#   plugins/quant-qc — worked example: resolves QuantConnect backtest ids via the QC API
export CC_VERIFY_PLUGIN="${CC_VERIFY_PLUGIN:-plugins/generic}"

# Optional research-escalation API keys (only if you wire deep-research tiers).
# export GEMINI_API_KEY=...
# export OPENAI_API_KEY=...
